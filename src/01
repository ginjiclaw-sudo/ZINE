<!DOCTYPE html>

<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WORLD ZINE — Issue 01: キリスト教</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=M+PLUS+Rounded+1c:wght@400;700;800;900&family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet">
<style>
:root {
  --coral: #FF4757;
  --blue: #2F86EB;
  --yellow: #FFD32A;
  --navy: #1A1A3E;
  --green: #00C9A7;
  --white: #FFFEF5;
  --light: #F0F4FF;
  --gray: #6B7280;
}

- { margin: 0; padding: 0; box-sizing: border-box; }

body {
background: #E8E4FF;
font-family: ‘Noto Sans JP’, sans-serif;
overflow-x: hidden;
}

.page {
max-width: 800px;
margin: 32px auto;
background: var(–white);
position: relative;
filter: drop-shadow(6px 6px 0 var(–navy)) drop-shadow(12px 12px 30px rgba(0,0,0,0.3));
}

/* ===== HALFTONE BG PATTERN ===== */
.halftone {
background-image: radial-gradient(circle, var(–navy) 1.5px, transparent 1.5px);
background-size: 16px 16px;
opacity: 0.07;
position: absolute;
inset: 0;
pointer-events: none;
}

/* ===== SERIES SPINE ===== */
.spine {
background: var(–navy);
padding: 0 28px;
display: flex;
justify-content: space-between;
align-items: center;
height: 44px;
}
.spine-title {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 18px;
color: var(–yellow);
letter-spacing: 4px;
}
.spine-badges {
display: flex;
gap: 10px;
align-items: center;
}
.badge {
font-family: ‘M PLUS Rounded 1c’, sans-serif;
font-size: 10px;
font-weight: 900;
padding: 3px 10px;
border-radius: 100px;
}
.badge.white { background: white; color: var(–navy); }
.badge.coral { background: var(–coral); color: white; }

/* ===== COVER ===== */
.cover {
background: var(–coral);
padding: 40px 40px 0;
position: relative;
overflow: hidden;
min-height: 480px;
display: grid;
grid-template-columns: 1.2fr 1fr;
gap: 30px;
align-items: end;
}

.cover-deco-circle {
position: absolute;
width: 380px;
height: 380px;
border-radius: 50%;
background: rgba(255,255,255,0.08);
top: -80px;
right: -80px;
}
.cover-deco-circle2 {
position: absolute;
width: 200px;
height: 200px;
border-radius: 50%;
background: var(–yellow);
opacity: 0.15;
bottom: 40px;
left: -60px;
}

.cover-left { padding-bottom: 50px; position: relative; z-index: 2; }
.cover-right { position: relative; z-index: 2; padding-bottom: 0; }

.issue-label {
display: inline-flex;
align-items: center;
gap: 8px;
background: var(–yellow);
color: var(–navy);
font-family: ‘M PLUS Rounded 1c’, sans-serif;
font-weight: 900;
font-size: 11px;
padding: 5px 14px;
border-radius: 100px;
margin-bottom: 20px;
letter-spacing: 1px;
}
.issue-label .dot {
width: 8px; height: 8px;
background: var(–coral);
border-radius: 50%;
display: inline-block;
}

.cover-main-title {
font-family: ‘Bebas Neue’, sans-serif;
color: white;
line-height: 0.9;
margin-bottom: 16px;
}
.cover-main-title .en { font-size: 100px; display: block; }
.cover-main-title .jp {
font-family: ‘M PLUS Rounded 1c’, sans-serif;
font-size: 36px;
font-weight: 900;
display: block;
letter-spacing: 8px;
}

.cover-tagline {
background: var(–navy);
color: white;
font-family: ‘M PLUS Rounded 1c’, sans-serif;
font-size: 13px;
font-weight: 700;
padding: 10px 16px;
display: inline-block;
border-radius: 8px;
line-height: 1.7;
}

/* Cover right — Stats Panel */
.cover-stats {
background: white;
border-radius: 16px 16px 0 0;
padding: 24px 20px;
}
.stats-title {
font-family: ‘M PLUS Rounded 1c’, sans-serif;
font-size: 11px;
font-weight: 900;
color: var(–gray);
letter-spacing: 3px;
text-transform: uppercase;
margin-bottom: 16px;
}
.stat-row {
display: flex;
align-items: baseline;
gap: 8px;
margin-bottom: 14px;
padding-bottom: 14px;
border-bottom: 1.5px dashed #E5E7EB;
}
.stat-row:last-child { border-bottom: none; margin-bottom: 0; }
.stat-num {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 36px;
color: var(–coral);
line-height: 1;
}
.stat-unit {
font-size: 11px;
color: var(–gray);
font-weight: 700;
}
.stat-label {
font-size: 12px;
color: var(–navy);
font-weight: 700;
flex: 1;
text-align: right;
}

/* ===== SECTIONS ===== */
section {
padding: 48px 44px;
position: relative;
overflow: hidden;
}
section:nth-child(even) { background: var(–light); }

.sec-tag {
display: inline-flex;
align-items: center;
gap: 6px;
font-family: ‘M PLUS Rounded 1c’, sans-serif;
font-size: 10px;
font-weight: 900;
letter-spacing: 3px;
text-transform: uppercase;
color: white;
background: var(–navy);
padding: 4px 12px;
border-radius: 4px;
margin-bottom: 14px;
}

h2 {
font-family: ‘M PLUS Rounded 1c’, sans-serif;
font-weight: 900;
font-size: 38px;
line-height: 1.15;
color: var(–navy);
margin-bottom: 24px;
}

h3 {
font-family: ‘M PLUS Rounded 1c’, sans-serif;
font-weight: 900;
font-size: 18px;
color: var(–navy);
margin-bottom: 10px;
}

p {
font-size: 14px;
line-height: 2;
color: #374151;
margin-bottom: 14px;
}

/* ===== COMIC PANEL GRID ===== */
.panel-grid {
display: grid;
gap: 3px;
margin: 24px 0;
}
.panel-grid.col3 { grid-template-columns: 1fr 1fr 1fr; }
.panel-grid.col2 { grid-template-columns: 1fr 1fr; }

.panel {
background: white;
border: 3px solid var(–navy);
padding: 20px;
position: relative;
}
.panel-num {
position: absolute;
top: -3px; left: -3px;
width: 28px; height: 28px;
background: var(–navy);
color: var(–yellow);
font-family: ‘Bebas Neue’, sans-serif;
font-size: 16px;
display: flex;
align-items: center;
justify-content: center;
}
.panel-icon {
font-size: 32px;
margin-bottom: 10px;
display: block;
}
.panel h3 { font-size: 16px; margin-bottom: 6px; }
.panel p { font-size: 12.5px; margin-bottom: 0; line-height: 1.8; }
.panel.yellow-bg { background: var(–yellow); }
.panel.coral-bg { background: var(–coral); color: white; }
.panel.coral-bg h3, .panel.coral-bg p { color: white; }
.panel.navy-bg { background: var(–navy); }
.panel.navy-bg h3 { color: var(–yellow); }
.panel.navy-bg p { color: rgba(255,255,255,0.8); }

/* ===== PULL QUOTE ===== */
.pq {
background: var(–yellow);
border: 3px solid var(–navy);
padding: 24px 28px;
margin: 28px 0;
position: relative;
border-radius: 0 20px 20px 20px;
}
.pq::before {
content: ‘’;
position: absolute;
top: -26px; left: -3px;
width: 0; height: 0;
border-left: 26px solid transparent;
border-right: 0;
border-bottom: 26px solid var(–navy);
}
.pq::after {
content: ‘’;
position: absolute;
top: -20px; left: 0;
width: 0; height: 0;
border-left: 22px solid transparent;
border-right: 0;
border-bottom: 22px solid var(–yellow);
}
.pq p {
font-family: ‘M PLUS Rounded 1c’, sans-serif;
font-weight: 700;
font-size: 16px;
line-height: 1.8;
color: var(–navy);
margin: 0;
}
.pq cite {
display: block;
font-size: 11px;
color: #6B7280;
margin-top: 8px;
font-style: normal;
font-weight: 700;
}

/* ===== STICKER ===== */
.sticker {
display: inline-block;
background: var(–green);
color: white;
font-family: ‘M PLUS Rounded 1c’, sans-serif;
font-weight: 900;
font-size: 11px;
padding: 6px 14px;
border-radius: 100px;
border: 2.5px solid var(–navy);
transform: rotate(-2deg);
}
.sticker.blue-s { background: var(–blue); }
.sticker.coral-s { background: var(–coral); }
.sticker.yellow-s { background: var(–yellow); color: var(–navy); }

/* ===== TIMELINE POP ===== */
.pop-timeline { margin: 28px 0; }
.pop-tl-item {
display: grid;
grid-template-columns: 90px 28px 1fr;
gap: 0 10px;
align-items: start;
margin-bottom: 20px;
}
.pop-tl-year {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 22px;
color: var(–coral);
text-align: right;
line-height: 1.2;
}
.pop-tl-line {
display: flex;
flex-direction: column;
align-items: center;
}
.pop-tl-dot {
width: 18px; height: 18px;
background: var(–navy);
border-radius: 50%;
border: 3px solid white;
box-shadow: 0 0 0 2px var(–navy);
flex-shrink: 0;
margin-top: 4px;
}
.pop-tl-vline {
width: 3px;
background: repeating-linear-gradient(to bottom, var(–navy) 0, var(–navy) 6px, transparent 6px, transparent 12px);
flex: 1;
min-height: 30px;
}
.pop-tl-content h4 {
font-family: ‘M PLUS Rounded 1c’, sans-serif;
font-weight: 900;
font-size: 14px;
color: var(–navy);
margin-bottom: 4px;
line-height: 1.4;
}
.pop-tl-content p { font-size: 12.5px; color: var(–gray); margin: 0; line-height: 1.7; }

/* ===== DENOMINATION CARDS ===== */
.denom-grid {
display: grid;
grid-template-columns: 1fr 1fr 1fr;
gap: 16px;
margin: 24px 0;
}
.denom-card {
border: 3px solid var(–navy);
border-radius: 12px;
overflow: hidden;
}
.denom-header {
padding: 14px;
text-align: center;
}
.denom-header .icon { font-size: 28px; display: block; margin-bottom: 6px; }
.denom-header h3 {
font-size: 16px;
margin-bottom: 0;
line-height: 1.2;
}
.denom-body {
padding: 14px;
background: var(–white);
}
.denom-body p { font-size: 12px; line-height: 1.8; margin-bottom: 8px; }
.denom-tag {
font-family: ‘M PLUS Rounded 1c’, sans-serif;
font-size: 10px;
font-weight: 900;
padding: 2px 8px;
border-radius: 4px;
background: var(–navy);
color: white;
display: inline-block;
margin-top: 4px;
}

/* ===== NEWS CONNECTION CARDS ===== */
.news-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 16px;
margin: 24px 0;
}
.news-card {
background: white;
border: 2.5px solid var(–navy);
border-radius: 12px;
padding: 18px;
position: relative;
overflow: hidden;
}
.news-card::before {
content: ‘’;
position: absolute;
top: 0; left: 0; right: 0;
height: 5px;
}
.news-card.card-coral::before { background: var(–coral); }
.news-card.card-blue::before { background: var(–blue); }
.news-card.card-green::before { background: var(–green); }
.news-card.card-yellow::before { background: var(–yellow); }
.news-icon { font-size: 24px; margin-bottom: 8px; display: block; }
.news-card h3 { font-size: 15px; margin-bottom: 6px; }
.news-card p { font-size: 12.5px; margin-bottom: 0; line-height: 1.8; }
.news-link {
display: inline-block;
margin-top: 10px;
font-family: ‘M PLUS Rounded 1c’, sans-serif;
font-size: 10px;
font-weight: 900;
color: var(–coral);
border-bottom: 2px solid var(–coral);
}

/* ===== CRITICAL BOX ===== */
.crit-box {
background: #FFF0F0;
border: 3px solid var(–coral);
border-radius: 12px;
padding: 24px;
margin: 24px 0;
position: relative;
}
.crit-box-label {
position: absolute;
top: -14px;
left: 16px;
background: var(–coral);
color: white;
font-family: ‘M PLUS Rounded 1c’, sans-serif;
font-weight: 900;
font-size: 11px;
padding: 4px 14px;
border-radius: 100px;
}
.crit-item {
display: flex;
gap: 12px;
margin-bottom: 14px;
align-items: flex-start;
}
.crit-item:last-child { margin-bottom: 0; }
.crit-emoji { font-size: 20px; flex-shrink: 0; margin-top: 2px; }
.crit-item p { font-size: 13px; line-height: 1.8; margin: 0; }
.crit-item strong { color: var(–coral); }

/* ===== CONCEPT MAP ===== */
.concept-map {
display: flex;
flex-direction: column;
gap: 3px;
margin: 24px 0;
}
.cm-row { display: flex; gap: 3px; }
.cm-cell {
flex: 1;
border: 3px solid var(–navy);
padding: 14px 16px;
background: white;
}
.cm-cell.wide { flex: 2; }
.cm-cell.colored { background: var(–navy); }
.cm-cell.colored .cm-label, .cm-cell.colored .cm-desc { color: white; }
.cm-label {
font-family: ‘M PLUS Rounded 1c’, sans-serif;
font-weight: 900;
font-size: 13px;
color: var(–coral);
margin-bottom: 4px;
}
.cm-desc { font-size: 12px; line-height: 1.7; color: #374151; }

/* ===== BACK COVER ===== */
.back-cover {
background: var(–navy);
padding: 50px 44px;
position: relative;
overflow: hidden;
}
.back-deco {
position: absolute;
font-family: ‘Bebas Neue’, sans-serif;
font-size: 180px;
color: rgba(255,255,255,0.03);
top: 10px;
right: -10px;
pointer-events: none;
}
.back-cover h2 {
color: var(–yellow);
font-size: 32px;
margin-bottom: 16px;
}
.back-cover > p { color: rgba(255,255,255,0.7); font-size: 13.5px; }

.next-series {
display: grid;
grid-template-columns: repeat(5, 1fr);
gap: 10px;
margin: 28px 0;
}
.ns-card {
border: 2px solid rgba(255,255,255,0.2);
border-radius: 10px;
padding: 14px 10px;
text-align: center;
transition: all 0.2s;
cursor: default;
}
.ns-card.active {
background: var(–coral);
border-color: var(–coral);
}
.ns-card .ns-num {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 13px;
color: var(–yellow);
display: block;
margin-bottom: 4px;
}
.ns-card.active .ns-num { color: white; }
.ns-card .ns-name {
font-family: ‘M PLUS Rounded 1c’, sans-serif;
font-weight: 700;
font-size: 12px;
color: rgba(255,255,255,0.9);
display: block;
}
.ns-card .ns-emoji { font-size: 22px; display: block; margin-bottom: 6px; }

.back-final {
border-top: 2px solid rgba(255,255,255,0.15);
padding-top: 24px;
margin-top: 24px;
display: flex;
justify-content: space-between;
align-items: center;
}
.back-final .tagline {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 26px;
color: white;
letter-spacing: 3px;
line-height: 1.3;
}
.back-final .tagline span { color: var(–yellow); }
.colophon {
font-size: 10px;
color: rgba(255,255,255,0.3);
font-family: ‘M PLUS Rounded 1c’, sans-serif;
text-align: right;
line-height: 2;
}

/* ===== DIVIDER ===== */
.fun-divider {
display: flex;
align-items: center;
gap: 14px;
margin: 28px 0;
}
.fun-divider::before, .fun-divider::after {
content: ‘’;
flex: 1;
height: 3px;
background: repeating-linear-gradient(to right, var(–navy) 0, var(–navy) 8px, transparent 8px, transparent 14px);
}
.fun-divider .icon { font-size: 20px; }

/* ===== ANIMATIONS ===== */
@keyframes popIn {
0% { opacity: 0; transform: scale(0.9) translateY(16px); }
100% { opacity: 1; transform: scale(1) translateY(0); }
}
.cover { animation: popIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both; }
section:nth-child(2) { animation: popIn 0.5s 0.05s both; }
section:nth-child(3) { animation: popIn 0.5s 0.1s both; }
section:nth-child(4) { animation: popIn 0.5s 0.15s both; }
section:nth-child(5) { animation: popIn 0.5s 0.2s both; }
section:nth-child(6) { animation: popIn 0.5s 0.25s both; }

/* ===== RESPONSIVE ===== */
@media (max-width: 680px) {
.cover { grid-template-columns: 1fr; }
.cover-main-title .en { font-size: 72px; }
.panel-grid.col3, .denom-grid, .next-series { grid-template-columns: 1fr 1fr; }
.news-grid { grid-template-columns: 1fr; }
section { padding: 36px 20px; }
h2 { font-size: 28px; }
}
</style>

</head>
